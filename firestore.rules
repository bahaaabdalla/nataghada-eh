rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write for the user's own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow reading usernames for validation
    // Allow creating a username only if the uid matches and it doesn't already exist
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      // Allow updates if they own it (not strictly necessary but good to have)
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
